# ── Supabase (Project Settings → API) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
# Server-only. NEVER expose in the browser. Used by /api routes.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ── Apps Script email relay ───────────────────────────────────
# Deploy apps-script/EmailService.gs as a Web App, paste its URL here.
EMAIL_RELAY_URL=https://script.google.com/macros/s/XXXX/exec
# Any long random string. Must match EMAIL_SECRET inside EmailService.gs.
EMAIL_RELAY_SECRET=change-me-to-a-64-char-random-string

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ── Paystack (optional — leave blank to keep manual payment flow) ──
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
