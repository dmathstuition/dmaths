# ── Supabase (Project Settings → API) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
# Server-only. NEVER expose in the browser. Used by /api routes.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ── Apps Script email relay ───────────────────────────────────
# Deploy apps-script/EmailService.gs as a Web App, paste its URL here.
EMAIL_RELAY_URL=https://script.google.com/macros/s/XXXX/exec
# Any long random string. Must match EMAIL_SECRET inside EmailService.gs.
EMAIL_RELAY_SECRET=change-me-to-a-64-char-random-string

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ── Cron (Supabase keep-alive) ────────────────────────────────
# Any long random string. Set the SAME value in Vercel → Settings → Environment
# Variables. Vercel injects it as `Authorization: Bearer <CRON_SECRET>` into the
# daily /api/cron/keepalive request (schedule lives in vercel.json).
CRON_SECRET=change-me-to-a-long-random-string

# ── Paystack (optional — leave blank to keep manual payment flow) ──
# Use the LIVE keys (pk_live_… / sk_live_…) once your account is approved.
# PAYSTACK_SECRET_KEY is server-only and ALSO signs the webhook (HMAC-SHA512).
# In the Paystack dashboard → Settings → API Keys & Webhooks, set the webhook
# URL to:  https://<your-domain>/api/paystack/webhook
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# ── AI learning buddy (optional — leave blank to hide it gracefully) ──
# Powers the floating "D-Maths A.I" hint chat in the portal (/api/assistant),
# using DeepSeek (OpenAI-compatible). Get a key at platform.deepseek.com and add
# billing. Server-only — NEVER expose in the browser.
# Unset = the widget shows a friendly "not switched on yet" message.
DEEPSEEK_API_KEY=
# Optional — model (defaults to deepseek-chat; use deepseek-reasoner for heavier
# step-by-step reasoning) and base URL (defaults to https://api.deepseek.com).
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── In-portal live classes (Jitsi) ────────────────────────────
# Live video/screen-share classrooms run in the portal via Jitsi. Works out of
# the box on Jitsi's free public server. For production branding + higher limits,
# self-host Jitsi (or use an 8x8 JaaS tenant) and set the domain here.
JITSI_DOMAIN=meet.jit.si
# Any long random string. Salts the (public) room names so only the app can
# derive a class's room. Set the same value across deployments.
LIVE_ROOM_SECRET=change-me-to-a-long-random-string
# Self-hosted Jitsi / 8x8 JaaS only — enables JWT auth so tutors are always the
# moderator (leave blank on the public server). See docs/self-host-jitsi.md.
JITSI_APP_ID=
JITSI_APP_SECRET=
# Optional override for the JWT `sub` claim (defaults to JITSI_DOMAIN).
JITSI_SUB=
# Set to "true" only when your Jitsi can record (self-hosted Jibri or JaaS) — the
# host then auto-starts recording and the link is filed into class recordings.
JITSI_RECORDING=
